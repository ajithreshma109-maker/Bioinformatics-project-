============================================================================
== 
# 3. LOAD & UNIFY SPLICED + UNSPLICED TRANSCRIPTS FOR OVERLAP ENGINE 
# 
============================================================================
== 
cat("Loading and combining spliced and unspliced datasets...\n") 
unspliced_tx <- fread(unspliced_csv_path) 
spliced_tx   <- fread(spliced_csv_path) 
# Combine both files vertically to process everything in one heavy pass 
combined_tx <- rbind(unspliced_tx, spliced_tx, fill = TRUE) 
selected_tx_clean <- unique(combined_tx, by = "transcript_id") 
target_ids <- selected_tx_clean$transcript_id 
# 
============================================================================
== 
# 4. HIGH-SPEED GENOMIC OVERLAP PROCESSING (POSTAR3 PEAK SELECTION) 
# 
============================================================================
== 
cat("Processing 3'UTR BED spatial coordinate tracks...\n") 
utr3_gr <- suppressWarnings(import(utr3_bed_path)) 
utr3_gr <- utr3_gr[mcols(utr3_gr)$name %in% target_ids] 
seqlevelsStyle(utr3_gr) <- "UCSC" 
cat("Loading and pre-filtering raw POSTAR3 dataset (RAM Optimized)...\n") 
postar_data <- fread(postar_path, sep="\t", header=FALSE) 
colnames(postar_data) <- c("chr", "start", "end", "rbp_peak_id", "strand",  
"rbp_name", "method", "cell_type", "source_id", "score") 
target_chroms <- unique(as.character(seqnames(utr3_gr))) 
postar_data <- postar_data[chr %in% target_chroms] 
cat("Converting target sequences to GRanges structures...\n") 
postar_gr <- makeGRangesFromDataFrame(postar_data, keep.extra.columns = TRUE) 
seqlevelsStyle(postar_gr) <- "UCSC" 
 
cat("Executing spatial findOverlaps genomic intersection matrix...\n") 
hits <- findOverlaps(utr3_gr, postar_gr) 
 
cat("Merging genomic overlap hits with combined transcript profiles...\n") 
overlaps_final <- as.data.table(postar_data[subjectHits(hits)]) 
overlaps_final$transcript_id <- mcols(utr3_gr)$name[queryHits(hits)] 
 
final_output <- merge(overlaps_final, selected_tx_clean,  
                      by = "transcript_id", all.x = TRUE, allow.cartesian = TRUE) 
 
cat("Exporting intermediate master overlap table to disk...\n") 
fwrite(final_output, output_path) 
 
