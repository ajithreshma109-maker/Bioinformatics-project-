============================================================================
== 
# FUNCTION FOR MODEL RUNNING & PLOTTING (Reusable for both datasets) 
# 
============================================================================
== 
generate_clean_rbp_plot <- function(data_subset, categories, hex_colors, title_text, filename) { 
   
  # 1. Compile contingency matrix summary 
  summary_df <- data_subset %>% 
    filter(three_utr_category %in% categories) %>% 
    group_by(three_utr_category, functional_module) %>% 
    tally() %>% 
    group_by(three_utr_category) %>% 
    mutate(proportion = n / sum(n)) 
   
  # 2. Run independent Chi-squared Test 
  contingency_table <- xtabs(n ~ three_utr_category + functional_module, data = summary_df) 
  chi_res <- chisq.test(contingency_table, simulate.p.value = TRUE, B = 2000) 
  res_df <- as.data.frame(chi_res$residuals) 
   
  # 3. Create gridless plot 
  polished_plot <- ggplot(res_df, aes(x = functional_module, y = Freq, fill = three_utr_category)) + 
    geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.7) + 
    geom_hline(yintercept = c(-2, 2), linetype = "dashed", color = "#8B1E0F", linewidth = 0.8) + 
    coord_flip() + 
    scale_fill_manual(values = hex_colors) + 
    labs( 
      title = title_text, 
      x = "Functional Module", 
      y = "Pearson Residuals", 
      fill = "three_utr_category" 
    ) + 
    theme_classic(base_size = 13, base_family = "sans") + 
    theme( 
      plot.title = element_text(face = "bold", size = 14, margin = margin(b = 10)), 
      axis.title.x = element_text(face = "bold", size = 13, margin = margin(t = 12)), 
      axis.title.y = element_text(face = "bold", size = 13, margin = margin(r = 12)), 
      axis.text = element_text(color = "#111111", face = "bold", size = 11), 
      axis.line = element_line(color = "#111111", linewidth = 0.8),  
      axis.ticks = element_line(color = "#111111", linewidth = 0.8), 
      axis.ticks.length = unit(0.15, "cm"), 
      panel.grid.major = element_blank(),  
      panel.grid.minor = element_blank(), 
      legend.position = "right", 
      legend.title = element_text(face = "bold", size = 11), 
      legend.text = element_text(size = 10) 
    ) 
   
  # Print to R panel and export save 
print(polished_plot) 
ggsave(paste0("C:/temp/UTR_workflow/", filename), plot = polished_plot, width = 8.5, height = 
5.5, dpi = 300) 
} 
