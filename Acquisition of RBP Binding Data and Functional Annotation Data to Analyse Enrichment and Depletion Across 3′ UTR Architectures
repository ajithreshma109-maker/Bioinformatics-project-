============================================================================
== 
cat("Reading compressed external RBP text-mining reference dictionary...\n") 
rbp_ref <- read.table(gzfile(rbp_ref_path), header = FALSE, sep = "\t",  
                      stringsAsFactors = FALSE, quote = "") 
colnames(rbp_ref) <- c("ensembl_id", "rbp_name", "entrez_id", "description", "aliases") 
 
cat("Mapping dynamic functional modules via regex database descriptions...\n") 
df_main <- as.data.frame(final_output) 
 
df_refined <- df_main %>% 
  left_join(rbp_ref %>% dplyr::select(rbp_name, description), by = "rbp_name") %>% 
  mutate(functional_module = case_when( 
    grepl("deadenylation|exosome|degradation|decay|catabolic", description, ignore.case = 
TRUE) ~ "Active Decay", 
    grepl("AU-rich|stabiliz|protection", description, ignore.case = TRUE) ~ "Structural Stability", 
    grepl("cleavage|polyadenylation|CPSF|CSTF", description, ignore.case = TRUE) ~ "Length 
Regulation (APA)", 
    grepl("translation|initiation|ribosome", description, ignore.case = TRUE) ~ "Translational 
Control", 
    grepl("splicing|spliceosome|snRNP", description, ignore.case = TRUE) ~ "Processing/Splicing", 
    TRUE ~ "Other/Multifunctional" 
  )) 
 
