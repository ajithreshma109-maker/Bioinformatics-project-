"plain"), legend.position = "right", plot.margin = margin(10, 15, 10, 10, "pt")) 
ggsave("C:/temp/UTR_workflow/3_UTR_MFE_Density_Distribution.png", plot = dist_3_plot, 
width = 8.5, height = 5.5, dpi = 300) 
# ------------------------------------------------------------------------------ 
# PLOT 3: 5' UTR STRUCTURAL CORRELATION GRAPH (BOLD AXES, NO DASHED MEDIAN) 
# ------------------------------------------------------------------------------ 
corr_5_plot <- ggplot(joint_master_pipeline_matrix, aes(x = five_utr, y = mfe_density_5utr, color 
= Structural_Status_5)) + 
geom_density_2d(aes(group = 1), color = "grey80", linewidth = 0.4, alpha = 0.5) + 
geom_point(alpha = 0.6, size = 1.3) + 
scale_color_manual(values = c("Unstructured" = "#56B4E9", "Moderate" = "#ed7d31", 
