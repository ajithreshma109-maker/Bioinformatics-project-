facet_wrap(~ Splicing_Status_5, scales = "free_x") + 
coord_cartesian(xlim = c(0, 1000), ylim = c(-0.6, 0.0)) + # Confirmed Y-limits match reference 
labs(x = "5' UTR Length (bp)", y = "MFE Density (kcal/mol/nt)", title = "5' UTR Structural 
Correlation", color = "Structural Status") + 
theme_bw(base_size = 14) + 
theme(plot.title = element_text(face = "bold", size = 14, margin = margin(b=15)), axis.title.x = 
element_text(face = "bold"), axis.title.y = element_text(face = "bold"), strip.background = 
element_blank(), strip.text = element_text(face = "bold", size = 13), legend.position = "bottom", 
panel.grid.major = element_blank(), panel.grid.minor = element_blank(), plot.margin = 
margin(10, 25, 15, 10, "pt")) 
ggsave("C:/temp/UTR_workflow/5_UTR_Structural_Correlation.png", plot = corr_5_plot, width = 
8.5, height = 6.2, dpi = 300) 
