message(">>> Dispatching visual rendering engines...") 
# ------------------------------------------------------------------------------ 
# PLOT 1: 5' UTR DISTRIBUTION PLOT (UNBOLDED AXES) 
# ------------------------------------------------------------------------------ 
dens5 <- density(joint_master_pipeline_matrix$mfe_density_5utr, na.rm = TRUE) 
df_dens5 <- data.frame(x = dens5$x, y = dens5$y) 
lbl_l5 <- paste0("Structured (<= ", round(q25_5, 2), ")"); lbl_m5 = paste0("Moderate (", 
round(q25_5, 2), " to ", round(q75_5, 2), ")"); lbl_u5 = paste0("Unstructured (> ", round(q75_5, 2), 
")") 
df_dens5 <- df_dens5 %>% mutate(group = factor(case_when(x <= q25_5 ~ lbl_l5, x > q25_5 & x 
<= q75_5 ~ lbl_m5, x > q75_5 ~ lbl_u5), levels = c(lbl_u5, lbl_m5, lbl_l5))) 
dist_5_plot <- ggplot(df_dens5) + 
geom_area(aes(x = x, y = y, fill = group), alpha = 0.85) + 
geom_line(aes(x = x, y = y), color = "black", linewidth = 1.1) + 
geom_vline(xintercept = c(q25_5, q75_5), linetype = "dashed", color = "gray40", linewidth = 0.6) 
+ 
scale_fill_manual(values = setNames(c("#56B4E9", "#ed7d31", "#F8766D"), c(lbl_u5, lbl_m5, 
lbl_l5))) + 
scale_y_continuous(expand = expansion(mult = c(0, 0.05))) + 
labs(title = "5' UTR MFE Density Distribution", x = "MFE Density Score (kcal/mol/nt)", y = 
"Density", fill = "Structural Status") + 
theme_classic(base_size = 14) + theme(plot.title = element_text(face = "bold", size = 14, margin 
= margin(b=15)), axis.title.x = element_text(face = "plain"), axis.title.y = element_text(face = 
"plain"), legend.position = "right", plot.margin = margin(10, 15, 10, 10, "pt")) 
ggsave("C:/temp/UTR_workflow/5_UTR_MFE_Density_Distribution.png", plot = dist_5_plot, 
width = 8.5, height = 5.5, dpi = 300) 
# ------------------------------------------------------------------------------ 
# PLOT 2: 3' UTR DISTRIBUTION PLOT (UNBOLDED AXES) 
# ------------------------------------------------------------------------------ 
dens3 <- density(joint_master_pipeline_matrix$mfe_density_3utr, na.rm = TRUE) 
df_dens3 <- data.frame(x = dens3$x, y = dens3$y) 
lbl_l3 <- paste0("Structured (<= ", round(q25_3, 2), ")"); lbl_m3 = paste0("Moderate (", 
