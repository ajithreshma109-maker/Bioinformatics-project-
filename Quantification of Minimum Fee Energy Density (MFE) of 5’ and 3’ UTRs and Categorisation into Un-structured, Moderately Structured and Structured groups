library(ggplot2) 
library(dplyr) 
library(stringr) 
 
# Establish directories and create missing folders 
dir.create("C:/temp/UTR_workflow/", recursive = TRUE, showWarnings = FALSE) 
 
# ------------------------------------------------------------------------------ 
# PHASE 1A: PARSE 5' UTR RAW THERMODYNAMIC OUTPUTS 
# ------------------------------------------------------------------------------ 
file_5utr <- "C:/temp/UTR_workflow/transcriptome_results.txt" 
 
ids_5  <- c() 
mfes_5 <- c() 
 
if (file.exists(file_5utr)) { 
    message(">>> Parsing multi-line raw structures from 5' UTR text archive...") 
    lines_5 <- readLines(file_5utr) 
    headers_5 <- which(grepl("ENST", lines_5) & !grepl("\\(-", lines_5)) 
     
    for (idx in headers_5) { 
        header_text <- lines_5[idx] 
        id_match <- regmatches(header_text, regexpr("ENST[0-9]+", header_text)) 
         
        search_range <- idx + 1:3 
        search_range <- search_range[search_range <= length(lines_5)] 
        mfe_line_idx <- search_range[grepl("\\(-[0-9.]+\\)", lines_5[search_range])] 
         
        if (length(mfe_line_idx) > 0 && !is.na(mfe_line_idx)) { 
            mfe_text <- lines_5[mfe_line_idx] 
            mfe_match <- regmatches(mfe_text, regexpr("\\(-[0-9.]+\\)", mfe_text)) 
            mfe_numeric <- as.numeric(gsub("[() ]", "", mfe_match)) 
             
            ids_5  <- c(ids_5, id_match) 
            mfes_5 <- c(mfes_5, mfe_numeric) 
        } 
    } 
    mfe_5_df <- data.frame(transcript_id = trimws(toupper(ids_5)), MFE_5 = mfes_5, 
stringsAsFactors = FALSE) %>% 
        distinct(transcript_id, .keep_all = TRUE) 
} else { 
    stop(paste("CRITICAL ERROR: Standalone 5' UTR raw text file completely missing at:", 
file_5utr)) 
} 
 
 
# ------------------------------------------------------------------------------ 
# PHASE 1B: PARSE ALL 4 SEQUENTIAL CHUNKS OF 3' UTR THERMODYNAMIC OUTPUTS 
# ------------------------------------------------------------------------------ 
utr3_files <- c( 
    "C:/Users/Reshma Ajith/Downloads/part1_results.txt", 
    "C:/Users/Reshma Ajith/Downloads/part2_results.txt", 
    "C:/Users/Reshma Ajith/Downloads/part3_results.txt", 
    "C:/Users/Reshma Ajith/Downloads/part4_results.txt" 
) 
 
ids_3  <- c() 
mfes_3 <- c() 
 
message(">>> Parsing multi-line tracking blocks across all 4 parts of 3' UTR text files...") 
 
for (file_3utr in utr3_files) { 
    if (file.exists(file_3utr)) { 
        message(paste("    Processing:", basename(file_3utr))) 
        lines_3 <- readLines(file_3utr) 
         
        current_id <- NULL 
        for (i in 1:length(lines_3)) { 
            current_line <- lines_3[i] 
             
            if (grepl("ENST[0-9]+", current_line) && !grepl("\\(", current_line)) { 
                current_id <- str_extract(current_line, "ENST[0-9]+") 
            } 
             
            if (grepl("\\(\\s*-?[0-9.]+\\)\\s*$", current_line)) { 
                mfe_match <- str_extract(current_line, "\\(\\s*-?[0-9.]+\\)\\s*$") 
                mfe_numeric <- as.numeric(gsub("[() ]", "", mfe_match)) 
                 
                if (!is.null(current_id) && !is.na(mfe_numeric)) { 
                    ids_3  <- c(ids_3, current_id) 
                    mfes_3 <- c(mfes_3, mfe_numeric) 
                    current_id <- NULL  
                } 
            } 
        } 
    } else { 
        warning(paste("    SKIPPED: Missing expected file location at:", file_3utr)) 
} 
} 
mfe_3_df <- data.frame(transcript_id = trimws(toupper(ids_3)), MFE_3 = mfes_3, 
stringsAsFactors = FALSE) %>% 
distinct(transcript_id, .keep_all = TRUE) 
# ------------------------------------------------------------------------------ 
# PHASE 2: METADATA EXTRACTION & STRUCTURAL INTEGRITY CORRECTION 
# ------------------------------------------------------------------------------ 
message(">>> Importing source files and compiling joint matrix profiles...") 
# Import lengths mapping metadata 
length_data <- read.csv("C:/Users/Reshma Ajith/Downloads/utr_expression_filtered_clean.csv", 
header = TRUE) 
length_map  <- length_data %>%  
dplyr::select(transcript_id, five_utr, three_utr) %>% 
mutate(transcript_id = trimws(toupper(transcript_id))) 
# Import functional categorizations metadata 
master_categories <- read.csv("C:/temp/UTR_workflow/Master_Transcript_Categories.csv", 
header = TRUE) %>% 
distinct(transcript_id, .keep_all = TRUE) %>% 
mutate(transcript_id = trimws(toupper(transcript_id))) 
# Establish core master matrix using left_join structures to insulate dataset from point dropouts 
joint_master_pipeline_matrix <- length_map %>% 
left_join(mfe_5_df, by = "transcript_id") %>% 
left_join(mfe_3_df, by = "transcript_id") %>% 
left_join(master_categories, by = "transcript_id") %>% 
# Filter out empty or unphysical coordinate dimensions 
    filter(five_utr >= 15 & three_utr >= 20) %>% 
    mutate( 
        # Native, accurate R density transformations (MFE / Segment Base Size) 
        mfe_density_5utr = MFE_5 / five_utr, 
        mfe_density_3utr = MFE_3 / three_utr, 
         
        # Splicing determinations driven directly by exon architecture counts rule 
        Splicing_Status_5 = factor(ifelse(num_exons_5utr == 1, "Unspliced", "Spliced"), levels = 
c("Unspliced", "Spliced")), 
        Splicing_Status_3 = factor(ifelse(is_spliced_3UTR == TRUE, "Spliced", "Unspliced"), levels = 
c("Unspliced", "Spliced")) 
    ) %>% 
    # Remove database calculation artifacts 
    filter(mfe_density_5utr >= -3.0 & mfe_density_3utr >= -3.0) 
 
# Isolate statistical quartile boundary tiers per subpopulation 
q25_5 <- quantile(joint_master_pipeline_matrix$mfe_density_5utr, 0.25, na.rm = TRUE) 
q75_5 <- quantile(joint_master_pipeline_matrix$mfe_density_5utr, 0.75, na.rm = TRUE) 
 
q25_3 <- quantile(joint_master_pipeline_matrix$mfe_density_3utr, 0.25, na.rm = TRUE) 
q75_3 <- quantile(joint_master_pipeline_matrix$mfe_density_3utr, 0.75, na.rm = TRUE) 
 
# Update descriptive structural classification designations 
joint_master_pipeline_matrix <- joint_master_pipeline_matrix %>% 
  mutate( 
    Structural_Status_5 = case_when( 
        mfe_density_5utr <= q25_5                        ~ "Structured", 
        mfe_density_5utr > q25_5 & mfe_density_5utr <= q75_5 ~ "Moderate", 
        mfe_density_5utr > q75_5                        ~ "Unstructured" 
    ), 
    Structural_Status_5 = factor(Structural_Status_5, levels = c("Unstructured", "Moderate", 
"Structured")), 
Structural_Status_3 = case_when( 
mfe_density_3utr <= q25_3                        
~ "Structured", 
mfe_density_3utr > q25_3 & mfe_density_3utr <= q75_3 ~ "Moderate", 
mfe_density_3utr > q75_3                        
), 
~ "Unstructured" 
Structural_Status_3 = factor(Structural_Status_3, levels = c("Unstructured", "Moderate", 
"Structured")) 
) 
# Export structural matrix data dumps 
write.csv(joint_master_pipeline_matrix, 
"C:/temp/UTR_workflow/Master_3UTR_Data_Fixed_Final.csv", row.names = FALSE) 
write.csv(joint_master_pipeline_matrix, 
"C:/temp/UTR_workflow/Master_Transcript_Categories_with_MFE.csv", row.names = FALSE) 
message(">>> Permanent master CSV files written cleanly to UTR_workflow.") 
