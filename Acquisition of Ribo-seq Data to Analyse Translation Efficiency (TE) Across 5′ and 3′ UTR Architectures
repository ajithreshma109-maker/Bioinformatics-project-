# 1. Load required Bioconductor and tidyverse packages
library(txdbmaker)
library(GenomicFeatures)
library(GenomicRanges)
library(rtracklayer)
library(dplyr)

# 2. Define precise file paths
gtf_file      <- "C:/Users/Reshma Ajith/Downloads/hg38.ensGene.gtf.gz"
bigwig_80s    <- "C:/Users/Reshma Ajith/Downloads/gwipsvizRiboseq.bw"
output_csv    <- "C:/temp/UTR_workflow/Transcript_Mean_Riboseq_Values.csv"

# Ensure the target directory exists
if (!dir.exists(dirname(output_csv))) {
  dir.create(dirname(output_csv), recursive = TRUE)
}

# 3. Build TxDb and extract the entire structural footprint for each transcript
print("Building TxDb object and extracting full transcript-level spans...")
txdb <- txdbmaker::makeTxDbFromGFF(file = gtf_file, format = "gtf", organism = "Homo sapiens")

# transcripts() extracts a single continuous GRanges per transcript (from absolute start to absolute end)
tx_span_ranges <- GenomicFeatures::transcripts(txdb, use.names = TRUE)

# 4. Load the 80S Ribo-seq BigWig track
bw_80s_selection <- rtracklayer::BigWigFile(bigwig_80s)

# 5. Harmonize Chromosome Nomenclature Styles via GenomeInfoDb
GenomicRanges::seqlevelsStyle(tx_span_ranges) <- GenomicRanges::seqlevelsStyle(bw_80s_selection)

# Restrict processing strictly to shared chromosomes to protect system memory
common_chroms  <- intersect(GenomicRanges::seqlevels(tx_span_ranges), GenomicRanges::seqlevels(bw_80s_selection))
tx_span_ranges <- GenomicRanges::keepSeqlevels(tx_span_ranges, common_chroms, pruning.mode = "coarse")

# 6. Query and import 80S coverage data matching entire transcript spans
print("Importing 80S signal coordinates across entire transcript ranges...")
bw_80s_signals <- rtracklayer::import.bw(bw_80s_selection, which = tx_span_ranges)

# 7. Map overlapping genomic signals onto full-length coordinates
print("Mapping coverage tracks to compute total transcript densities...")
overlaps  <- GenomicRanges::findOverlaps(tx_span_ranges, bw_80s_signals)
scores_df <- data.frame(
  tx_idx  = queryHits(overlaps),
  signal  = score(bw_80s_signals[subjectHits(overlaps)]),
  width   = width(pintersect(tx_span_ranges[queryHits(overlaps)], bw_80s_signals[subjectHits(overlaps)])),
  stringsAsFactors = FALSE
)

# 8. Use dplyr to calculate the true weighted mean across the continuous transcript length
mean_80s_profiles <- scores_df %>%
  group_by(tx_idx) %>%
  summarize(mean_80S_riboseq = sum(signal * width) / sum(width)) %>%
  ungroup()

# Assign calculated scores back into the main range matrix
tx_span_ranges$mean_80S_riboseq <- 0
tx_span_ranges$mean_80S_riboseq[mean_80s_profiles$tx_idx] <- mean_80s_profiles$mean_80S_riboseq

# 9. Format output table and clean up transcript identifiers
final_transcript_matrix <- as.data.frame(tx_span_ranges) %>%
  select(tx_name, mean_80S_riboseq) %>%
  rename(transcript_id = tx_name) %>%
  mutate(
    # Strip version decimal tags (e.g. ENST00000263100.8 -> ENST00000263100)
    transcript_id = sub("\\..*", "", transcript_id)
  ) %>%
  # Deduplicate to preserve a single row per unique transcript model
  distinct(transcript_id, .keep_all = TRUE)

# 10. Save the final un-skewed translational footprint scores
write.csv(final_transcript_matrix, file = output_csv, row.names = FALSE)

print("Translation workflow complete! Full continuous transcript 80S values saved.")

